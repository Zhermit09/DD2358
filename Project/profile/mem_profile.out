    44   98.152 MiB 60803978.559 MiB      619791   @profile
    45                                         def scatter(data, lc, value):
    46   98.152 MiB    0.000 MiB      619791       i = int(numpy.trunc(lc[0]))
    47   98.152 MiB    0.000 MiB      619791       j = int(numpy.trunc(lc[1]))
    48   98.152 MiB    0.000 MiB      619791       di = lc[0] - i
    49   98.152 MiB    0.000 MiB      619791       dj = lc[1] - j
    50                                         
    51   98.152 MiB    0.000 MiB      619791       data[i][j] += (1 - di) * (1 - dj) * value
    52   98.152 MiB    0.000 MiB      619791       data[i + 1][j] += di * (1 - dj) * value
    53   98.152 MiB    0.000 MiB      619791       data[i][j + 1] += (1 - di) * dj * value
    54   98.152 MiB    0.000 MiB      619791       data[i + 1][j + 1] += di * dj * value


