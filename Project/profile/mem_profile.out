    83   98.152 MiB 98244.648 MiB        1002   @profile
    84                                         def solvePotential(phi, max_it=100):
    85                                             # make copy of dirichlet nodes
    86   98.152 MiB    0.000 MiB        1002       P = numpy.copy(phi)
    87                                         
    88   98.152 MiB    0.000 MiB        1002       g = numpy.zeros_like(phi)
    89   98.152 MiB    0.000 MiB        1002       dz2 = dz * dz
    90   98.152 MiB    0.000 MiB        1002       dr2 = dr * dr
    91                                         
    92   98.152 MiB    0.000 MiB        1002       rho_e = numpy.zeros_like(phi)
    93                                         
    94                                             # set radia
    95   98.152 MiB    0.000 MiB        1002       r = numpy.zeros_like(phi)
    96   98.152 MiB    0.004 MiB       37074       for i in range(nz):
    97   98.152 MiB    0.004 MiB      468936           for j in range(nr):
    98   98.152 MiB    0.000 MiB      432864               r[i][j] = R(j)
    99                                         
   100   98.152 MiB    0.000 MiB      102102       for it in range(max_it):
   101                                                 # compute RHS
   102                                                 # rho_e = QE*n0*numpy.exp(numpy.subtract(phi,phi0)/kTe)
   103                                         
   104                                                 # for i in range(1,nz-1):
   105                                                 #    for j in range(1,nr-1):
   106                                         
   107                                                 #        if (cell_type[i,j]>0):
   108                                                 #            continue
   109                                         
   110                                                 #       rho_e=QE*n0*math.exp((phi[i,j]-phi0)/kTe)
   111                                                 #        b = (rho_i[i,j]-rho_e)/EPS0;
   112                                                 #        g[i,j] = (b +
   113                                                 #                 (phi[i,j-1]+phi[i,j+1])/dr2 +
   114                                                 #                 (phi[i,j-1]-phi[i,j+1])/(2*dr*r[i,j]) +
   115                                                 #                 (phi[i-1,j] + phi[i+1,j])/dz2) / (2/dr2 + 2/dz2)
   116                                         
   117                                                 #        phi[i,j]=g[i,j]
   118                                         
   119                                                 # compute electron term
   120   98.152 MiB    0.008 MiB      101100           rho_e = QE * n0 * numpy.exp(numpy.subtract(P, phi0) / kTe)
   121   98.152 MiB    0.066 MiB      101100           b = numpy.where(cell_type <= 0, (rho_i - rho_e) / EPS0, 0)
   122                                         
   123                                                 # regular form inside
   124   98.152 MiB    0.000 MiB      505500           g[1:-1, 1:-1] = (b[1:-1, 1:-1] +
   125   98.152 MiB    0.000 MiB      101100                            (phi[1:-1, 2:] + phi[1:-1, :-2]) / dr2 +
   126   98.152 MiB    0.062 MiB      101100                            (phi[1:-1, 0:-2] - phi[1:-1, 2:]) / (2 * dr * r[1:-1, 1:-1]) +
   127   98.152 MiB    0.000 MiB      202200                            (phi[2:, 1:-1] + phi[:-2, 1:-1]) / dz2) / (2 / dr2 + 2 / dz2)
   128                                         
   129                                                 # neumann boundaries
   130   98.152 MiB    0.000 MiB      101100           g[0] = g[1]  # left
   131   98.152 MiB    0.000 MiB      101100           g[-1] = g[-2]  # right
   132   98.152 MiB    0.000 MiB      101100           g[:, -1] = g[:, -2]  # top
   133   98.152 MiB    0.000 MiB      101100           g[:, 0] = g[:, 1]
   134                                         
   135                                                 # dirichlet nodes
   136   98.152 MiB    0.000 MiB      101100           phi = numpy.where(cell_type > 0, P, g)
   137                                         
   138   98.152 MiB    0.000 MiB        1002       return phi


