    59   52.395 MiB   52.395 MiB           1   @profile
    60                                         def calculate_z_serial_purepython(maxiter, zs, cs):
    61                                             """Calculate output list using Julia update rule"""
    62   52.395 MiB    0.000 MiB           1       output = [0] * len(zs)
    63   52.520 MiB    0.000 MiB       40001       for i in range(len(zs)):
    64   52.520 MiB    0.000 MiB       40000           n = 0
    65   52.520 MiB    0.000 MiB       40000           z = zs[i]
    66   52.520 MiB    0.000 MiB       40000           c = cs[i]
    67   52.520 MiB    0.121 MiB     1369666           while abs(z) < 2 and n < maxiter:
    68   52.520 MiB    0.000 MiB     1329666               z = z * z + c
    69   52.520 MiB    0.000 MiB     1329666               n += 1
    70   52.520 MiB    0.004 MiB       40000           output[i] = n
    71   52.520 MiB    0.000 MiB           1       return output


